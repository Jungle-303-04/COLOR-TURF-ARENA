# Browser-visible URL used by phone QR codes. Replace localhost with the PC LAN IP.
PUBLIC_BASE_URL=http://localhost:8080
ADMIN_TOKEN=demo-admin
OPS_EVENT_TOKEN=demo-ops
SERVER_VERSION=v1.1.3
CANARY_SERVER_VERSION=v1.2.0
GIT_SHA=local
IMAGE_TAG=local
SNAPSHOT_INTERVAL_MS=1000
DEMO_AUTO_SEED=false
DEMO_BOT_COUNT=0
CANARY_TICK_DELAY_MS=250

# Optional platform integration
OPS_PLATFORM_WEBHOOK_URL=
OPS_PLATFORM_WEBHOOK_TOKEN=

# Explicit opt-in; otherwise the shutdown Chaos API returns 409.
ALLOW_DEMO_SERVER_SHUTDOWN=false
